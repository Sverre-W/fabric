{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "Origins": []
  },
  "Tenancy": {
    "Mode": "SingleTenant",
    "DefaultTenant": {
      "Id": "main-tenant",
      "Oidc": {
        "MetadataUrl": "http://localhost/.well-known/openid-configuration",
        "ClientId": "fabric",
        "RequireHttpsMetadata": false
      }
    }
  },
  "AllowedHosts": "*",
  "EnableSwagger" : false
}
