{
  "name": "fabric-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "api:generate": "openapi-typescript http://localhost:5245/openapi/v1.json -o src/shared/api/generated/schema.d.ts",
    "copy:elsa-studio-assets": "rm -rf public/_content public/_framework public/appsettings.json public/Elsa.Studio.Host.CustomElements.styles.css && mkdir -p public && cp -r ../..//../elsa-studio/packages/wasm/wwwroot/_content public/ && cp -r ../..//../elsa-studio/packages/wasm/wwwroot/_framework public/ && cp ../..//../elsa-studio/packages/wasm/wwwroot/appsettings.json public/ && if [ -f ../..//../elsa-studio/packages/wasm/wwwroot/Elsa.Studio.Host.CustomElements.styles.css ]; then cp ../..//../elsa-studio/packages/wasm/wwwroot/Elsa.Studio.Host.CustomElements.styles.css public/; fi",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "latest",
    "@tailwindcss/vite": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@zxing/browser": "^0.2.0",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "^4.4.0",
    "i18next": "latest",
    "lucide-react": "latest",
    "oidc-client-ts": "^3.5.0",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.6.0",
    "react": "latest",
    "react-day-picker": "^10.0.1",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "react-i18next": "latest",
    "react-oidc-context": "^3.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "latest",
    "tailwindcss": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "openapi-typescript": "^7.13.0",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
